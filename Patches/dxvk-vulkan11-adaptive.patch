# DXVK Vulkan 1.1 adaptive-fallback patch
#
# Local modification to references/fbraz3-dxvk (at 46a3bc01) used to build the
# libdxvk_d3d8/d3d9 .so libraries the Android APK packages as jniLibs.
#
# DXVK unconditionally required Vulkan 1.3 (DxvkDeviceFilter::testAdapter,
# meson.build's glslang --target-env) and chained the monolithic
# VkPhysicalDeviceVulkan12/13Features/Properties structs regardless of the
# adapter's real apiVersion -- both invalid per spec and fatal in practice on
# Vulkan 1.1/1.2-only GPUs (Mali, Unisoc, PowerVR), which vkCreateDevice
# rejects outright ("DxvkAdapter: Failed to create device", see issue #5).
# Qualcomm/Adreno devices are covered separately via Turnip driver injection
# and are unaffected by this patch (real apiVersion 1.3 -> unchanged codepath).
#
# This patch lowers the hard floor to Vulkan 1.1 and makes support for the six
# features DXVK genuinely hard-requires (vk12: vulkanMemoryModel,
# hostQueryReset, timelineSemaphore; vk13: synchronization2, dynamicRendering,
# maintenance4) adaptive: on a >=1.3 device nothing changes; on a 1.1/1.2
# device DXVK instead queries and enables the original KHR/EXT extensions
# these were promoted from (VK_KHR_dynamic_rendering, VK_KHR_synchronization2,
# VK_KHR_maintenance4, VK_KHR_timeline_semaphore, VK_KHR_vulkan_memory_model,
# VK_EXT_host_query_reset), including a vkGetDeviceProcAddr KHR-suffix
# fallback in the Vulkan function loader for the promoted "2"/dynamic
# rendering commands, whose unsuffixed names are only guaranteed to resolve
# on true Vulkan 1.3. meson.build's shader target-env drops to vulkan1.1
# (SPIR-V 1.3), which loads unchanged on 1.1 through 1.3+ devices.
#
# Apply with: git -C references/fbraz3-dxvk apply ../../Patches/dxvk-vulkan11-adaptive.patch
# Applied after dxvk-android.patch and dxvk-ios.patch.
diff --git a/meson.build b/meson.build
index 26afed4..a1bce20 100644
--- a/meson.build
+++ b/meson.build
@@ -185,7 +185,9 @@ def_spec_ext = '.def'
 glsl_compiler = find_program('glslang', 'glslangValidator')
 glsl_args = [
   '--quiet',
-  '--target-env', 'vulkan1.3',
+  # SPIR-V 1.3 (the vulkan1.1 mapping) loads on any Vulkan 1.1+ device,
+  # including 1.3 ones -- no need for a separate build per API tier.
+  '--target-env', 'vulkan1.1',
   '--vn', '@BASENAME@',
   '--depfile', '@DEPFILE@',
   '@INPUT@',
