 #define VULKAN_FN(name) \
   ::PFN_ ## name name = reinterpret_cast<::PFN_ ## name>(sym(#name))
 
+// For functions promoted to Vulkan 1.2/1.3 core: the unsuffixed name is only
+// guaranteed to resolve via vkGetDeviceProcAddr when the device's apiVersion
+// covers the promotion. On Vulkan 1.1/1.2-only adapters where we instead
+// enabled the original KHR extension, only the ...KHR-suffixed entry point
+// is guaranteed, so fall back to it (both names are spec-mandated aliases
+// with identical signatures whenever either is available).
+#define VULKAN_FN_FALLBACK(name, fallback) \
+  ::PFN_ ## name name = [this]() -> ::PFN_ ## name { \
+    auto fn = sym(#name); \
+    if (!fn) fn = sym(#fallback); \
+    return reinterpret_cast<::PFN_ ## name>(fn); \
+  }()
+
 using PFN_wine_vkAcquireKeyedMutex = VkResult (VKAPI_PTR *)(VkDevice device, VkDeviceMemory memory, uint64_t key, uint32_t timeout_ms);
 using PFN_wine_vkReleaseKeyedMutex = VkResult (VKAPI_PTR *)(VkDevice device, VkDeviceMemory memory, uint64_t key);
 
